rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - role: string (required, 'admin' | 'user')
    //   - status: string (required, 'active' | 'banned' | 'pending')
    //   - coins: number (required)
    //   - freeAttempts: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: activityLogs
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - userName: string (required)
    //   - action: string (required)
    //   - details: string (required)
    //   - timestamp: timestamp (required)
    //
    // [Other collections: products, categories, orders, licenseKeys, settings]
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "uhbijnokmpl098900@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['id', 'name', 'role', 'status', 'coins', 'freeAttempts', 'createdAt']) &&
             data.id is string && data.name is string &&
             data.role in ['admin', 'user'] &&
             data.status in ['active', 'banned', 'pending'] &&
             data.coins is number && data.freeAttempts is number;
    }

    function isValidActivityLog(data) {
      return hasRequiredFields(['userId', 'userName', 'action', 'details', 'timestamp']) &&
             (isAuthenticated() ? data.userId == request.auth.uid : data.userId == 'guest_admin') &&
             data.userName is string &&
             data.action is string &&
             data.details is string &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user') || isAdmin();
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if (isAuthenticated() || request.resource.data.userId == 'guest_admin') && isValidActivityLog(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /licenseKeys/{keyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated(); // Logic handles redemption
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banned_emails/{emailId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banned_ips/{ipId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banned_devices/{deviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /presetBackgrounds/{bgId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
